# Render API service profile. Set these in Render's environment dashboard.
APP_MODE="production"
NODE_ENV="production"
API_HOST="0.0.0.0"
API_PORT="10000"

# Supabase Postgres connection string for Prisma.
# Use the Supavisor Session pooler URL from Supabase Connect. It ends with :5432.
# Direct connection also works when the host supports IPv6 or has the IPv4 add-on.
API_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# At least 32 chars. Generate a real random value before deploying.
COOKIE_SECRET="replace-with-a-random-secret-of-at-least-32-chars"

# Vercel app URL(s), comma-separated if you also use preview domains.
CORS_ORIGIN="https://your-duel-hub.vercel.app"

# Public Render URL, used by operators and matching the frontend API_BASE_URL.
API_BASE_URL="https://your-duel-hub-api.onrender.com"
