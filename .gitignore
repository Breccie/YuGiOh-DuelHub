# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/apps/frontend/.next/
/out/
/prisma/*.db
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# production
/build
/dist-desktop
/output/
/apps/api/generated/

# misc
.DS_Store
*.pem
/tmp/
/tmp-*.png
/tmp-*.log
screenshots/
playwright-report/
test-results/
/.codex-*.log
/.codex-*.db
/.playwright-cli/
/apps/api/dist/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
apps/frontend/next-env.d.ts
