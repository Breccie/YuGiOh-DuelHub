{
  "services": {
    "web": {
      "root": ".",
      "framework": "nextjs",
      "installCommand": "npm ci",
      "buildCommand": "npm run db:generate && npm run build",
      "outputDirectory": "apps/frontend/.next"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
